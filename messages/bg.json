      "p1": "\u0410\u0442\u043b\u0430\u043d\u0442 \u041b\u043e\u0433\u0438\u0441\u0442\u0438\u043a\u0441 \u0441\u043f\u0430\u0437\u0432\u0430 \u043c\u0435\u0436\u0434\u0443\u043d\u0430\u0440\u043e\u0434\u043d\u0438\u0442\u0435 \u0440\u0430\u0437\u043f\u043e\u0440\u0435\u0434\u0431\u0438 \u0437\u0430 \u0437\u0430\u0449\u0438\u0442\u0430 \u043d\u0430 \u0434\u0430\u043d\u043d\u0438\u0442\u0435 \u0438 \u0438\u0437\u0438\u0441\u043a\u0432\u0430\u043d\u0438\u044f\u0442\u0430 \u043d\u0430 GDPR.",
      "p2": "\u0421\u044a\u0431\u0438\u0440\u0430\u043c\u0435 \u0441\u0430\u043c\u043e \u0434\u0430\u043d\u043d\u0438, \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u0438 \u0437\u0430 \u043e\u0431\u0440\u0430\u0431\u043e\u0442\u043a\u0430 \u043d\u0430 \u0437\u0430\u043f\u0438\u0442\u0432\u0430\u043d\u0438\u044f \u0438 \u043a\u043e\u043d\u0442\u0430\u043a\u0442 \u0441 \u0432\u0430\u0441: \u0438\u043c\u0435, \u0442\u0435\u043b\u0435\u0444\u043e\u043d, \u0438\u043c\u0435\u0439\u043b, \u0433\u0440\u0430\u0434 \u0438 \u0441\u044a\u043e\u0431\u0449\u0435\u043d\u0438\u0435.",
      "p3": "\u0414\u0430\u043d\u043d\u0438\u0442\u0435 \u0441\u0435 \u0438\u0437\u043f\u043e\u043b\u0437\u0432\u0430\u0442 \u0435\u0434\u0438\u043d\u0441\u0442\u0432\u0435\u043d\u043e \u0437\u0430 \u043e\u0442\u0433\u043e\u0432\u0430\u0440\u044f\u043d\u0435 \u043d\u0430 \u0437\u0430\u043f\u0438\u0442\u0432\u0430\u043d\u0438\u044f, \u043f\u043e\u0434\u0433\u043e\u0442\u0432\u044f\u043d\u0435 \u043d\u0430 \u043e\u0444\u0435\u0440\u0442\u0438 \u0438 \u0438\u0437\u043f\u044a\u043b\u043d\u0435\u043d\u0438\u0435 \u043d\u0430 \u0434\u043e\u0433\u043e\u0432\u043e\u0440\u0435\u043d\u0438 \u0443\u0441\u043b\u0443\u0433\u0438. \u041d\u0435 \u043f\u0440\u043e\u0434\u0430\u0432\u0430\u043c\u0435 \u043b\u0438\u0447\u043d\u0438 \u0434\u0430\u043d\u043d\u0438 \u043d\u0430 \u0442\u0440\u0435\u0442\u0438 \u0441\u0442\u0440\u0430\u043d\u0438 \u0431\u0435\u0437 \u0437\u0430\u043a\u043e\u043d\u043e\u0432\u043e \u043e\u0441\u043d\u043e\u0432\u0430\u043d\u0438\u0435.",
      "p4": "\u0418\u0437\u043f\u043e\u043b\u0437\u0432\u0430\u043c\u0435 \u0431\u0438\u0441\u043a\u0432\u0438\u0442\u043a\u0438 \u0437\u0430 \u043f\u043e\u0434\u043e\u0431\u0440\u044f\u0432\u0430\u043d\u0435 \u043d\u0430 \u0441\u0430\u0439\u0442\u0430 \u0438 \u0430\u043d\u0430\u043b\u0438\u0437 \u043d\u0430 \u043f\u043e\u0441\u0435\u0449\u0430\u0435\u043c\u043e\u0441\u0442\u0442\u0430. \u041c\u043e\u0436\u0435\u0442\u0435 \u0434\u0430 \u043e\u0442\u043a\u0430\u0436\u0435\u0442\u0435 \u043d\u0435\u0437\u0430\u0434\u044a\u043b\u0436\u0438\u0442\u0435\u043b\u043d\u0438 \u0431\u0438\u0441\u043a\u0432\u0438\u0442\u043a\u0438 \u043e\u0442 \u043d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0438\u0442\u0435 \u043d\u0430 \u0431\u0440\u0430\u0443\u0437\u044a\u0440\u0430.",
      "p5": "\u0418\u043c\u0430\u0442\u0435 \u043f\u0440\u0430\u0432\u043e \u043d\u0430 \u0434\u043e\u0441\u0442\u044a\u043f, \u043a\u043e\u0440\u0435\u043a\u0446\u0438\u044f, \u0438\u0437\u0442\u0440\u0438\u0432\u0430\u043d\u0435 \u0438 \u043e\u0433\u0440\u0430\u043d\u0438\u0447\u0430\u0432\u0430\u043d\u0435 \u043d\u0430 \u043e\u0431\u0440\u0430\u0431\u043e\u0442\u043a\u0430\u0442\u0430 \u043d\u0430 \u0432\u0430\u0448\u0438\u0442\u0435 \u0434\u0430\u043d\u043d\u0438. \u0417\u0430 \u0443\u043f\u0440\u0430\u0436\u043d\u044f\u0432\u0430\u043d\u0435 \u043d\u0430 \u043f\u0440\u0430\u0432\u0430\u0442\u0430 \u0441\u0438 \u0441\u0435 \u0441\u0432\u044a\u0440\u0436\u0435\u0442\u0435 \u0441 \u043d\u0430\u0441 \u0447\u0440\u0435\u0437 \u043a\u043e\u043d\u0442\u0430\u043a\u0442\u043d\u0430\u0442\u0430 \u0444\u043e\u0440\u043c\u0430 \u0438\u043b\u0438 \u043d\u0430 \u043f\u043e\u0441\u043e\u0447\u0435\u043d\u0438\u044f \u0438\u043c\u0435\u0439\u043b.",
      "p6": "\u0414\u0430\u043d\u043d\u0438\u0442\u0435 се съхраняват толкова дълго, колкото е необходимо за целите, за които са събрани, или съгласно приложимото законодателство.",
      "p7": "\u041f\u0440\u0438 \u0432\u044a\u043f\u0440\u043e\u0441\u0438 \u043e\u0442\u043d\u043e\u0441\u043d\u043e \u0437\u0430\u0449\u0438\u0442\u0430\u0442\u0430 \u043d\u0430 \u0434\u0430\u043d\u043d\u0438\u0442\u0435 \u043c\u043e\u0436\u0435\u0442\u0435 \u0434\u0430 \u0441\u0435 \u0441\u0432\u044a\u0440\u0436\u0435\u0442\u0435 \u0441 \u0410\u0442\u043b\u0430\u043d\u0442 \u041b\u043e\u0433\u0438\u0441\u0442\u0438\u043a\u0441 \u043d\u0430 \u0430\u0434\u0440\u0435\u0441\u0430, посочен \u043d\u0430 \u0441\u0442\u0440\u0430\u043d\u0438\u0446\u0430 \u041a\u043e\u043d\u0442\u0430\u043a\u0442\u0438."
    },
    "terms": {
      "title": "\u0423\u0441\u043b\u043e\u0432\u0438\u044f \u0437\u0430 \u043f\u043e\u043b\u0437\u0432\u0430\u043d\u0435",
      "p1": "\u0421 \u0438\u0437\u043f\u043e\u043b\u0437\u0432\u0430\u043d\u0435\u0442\u043e \u043d\u0430 \u0441\u0430\u0439\u0442\u0430 atlant.bg \u043f\u0440\u0438\u0435\u043c\u0430\u0442\u0435 \u043d\u0430\u0441\u0442\u043e\u044f\u0449\u0438\u0442\u0435 \u0443\u0441\u043b\u043e\u0432\u0438\u044f. \u0421\u0430\u0439\u0442\u044a\u0442 \u0438\u043d\u0444\u043e\u0440\u043c\u0438\u0440\u0430 \u0437\u0430 \u0443\u0441\u043b\u0443\u0433\u0438\u0442\u0435 \u043d\u0430 Atlant Logistics & Relocations.",
      "p2": "\u0421\u044a\u0434\u044a\u0440\u0436\u0430\u043d\u0438\u0435\u0442\u043e \u043d\u0430 \u0441\u0430\u0439\u0442\u0430 \u0435 \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u043e\u043d\u043d\u043e \u0438 \u043d\u0435 \u0441\u044a\u0437\u0434\u0430\u0432\u0430 \u0430\u0432\u0442\u043e\u043c\u0430\u0442\u0438\u0447\u043d\u043e \u0434\u043e\u0433\u043e\u0432\u043e\u0440. \u0414\u043e\u0433\u043e\u0432\u043e\u0440 \u0441\u0435 \u0441\u043a\u043b\u044e\u0447\u0432\u0430 \u0441\u043b\u0435\u0434 \u043f\u0438\u0441\u043c\u0435\u043d\u043e \u043f\u043e\u0442\u0432\u044a\u0440\u0436\u0434\u0435\u043d\u0438\u0435 \u043d\u0430 \u043e\u0444\u0435\u0440\u0442\u0430.",
      "p3": "\u0412\u0441\u0438\u0447\u043a\u0438 \u0442\u0435\u043a\u0441\u0442\u043e\u0432\u0435 \u043c\u0430\u0442\u0435\u0440\u0438\u0430\u043b\u0438, \u0438\u0437\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u044f \u0438 \u0442\u044a\u0440\u0433\u043e\u0432\u0441\u043a\u0438 \u043c\u0430\u0440\u043a\u0438 \u0441\u0430 \u0437\u0430\u0449\u0438\u0442\u0435\u043d\u0438 \u043e\u0442 \u0430\u0432\u0442\u043e\u0440\u0441\u043a\u043e \u043f\u0440\u0430\u0432\u043e.",
      "p4": "\u041d\u0435 \u0435 \u0440\u0430\u0437\u0440\u0435\u0448\u0435\u043d\u043e \u043d\u0435\u043e\u0442\u043e\u0440\u0438\u0437\u0438\u0440\u0430\u043d\u043e \u043a\u043e\u043f\u0438\u0440\u0430\u043d\u0435 \u043d\u0430 \u0441\u044a\u0434\u044a\u0440\u0436\u0430\u043d\u0438\u0435\u0442\u043e \u0431\u0435\u0437 \u043f\u0438\u0441\u043c\u0435\u043d\u043e \u0441\u044a\u0433\u043b\u0430\u0441\u0438\u0435.",
      "p5": "\u0417\u0430 \u0437\u0430\u043f\u0438\u0442\u0432\u0430\u043d\u0438\u044f \u0438 \u043e\u0444\u0435\u0440\u0442\u0438 \u043f\u0440\u0435\u0434\u043e\u0441\u0442\u0430\u0432\u044f\u0442\u0435 \u0432\u044f\u0437\u043d\u0438 \u0438 \u0430\u043a\u0442\u0443\u0430\u043b\u043d\u0438 \u0434\u0430\u043d\u043d\u0438. Atlant \u043d\u0435 \u043d\u043e\u0441\u0438 \u043e\u0442\u0433\u043e\u0432\u043e\u0440\u043d\u043e\u0441\u0442 \u0437\u0430 \u043d\u0435\u0442\u043e\u0447\u043d\u0438 \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u0438, предоставени от клиента.",
      "p6": "\u0423\u0441\u043b\u0443\u0433\u0438\u0442\u0435 \u0441\u0435 \u0438\u0437\u043f\u044a\u043b\u043d\u044f\u0432\u0430\u0442 \u0441\u043f\u043e\u0440\u0435\u0434 \u0434\u043e\u0433\u043e\u0432\u043e\u0440\u0435\u043d\u0438 \u0443\u0441\u043b\u043e\u0432\u0438\u044f, \u0441\u0440\u043e\u0446\u0435\u043d\u0438 \u0438 \u0441\u0442\u0430\u043d\u0434\u0430\u0440\u0442\u0438 \u0437\u0430 \u043a\u0430\u0447\u0435\u0441\u0442\u0432\u043e ISO 9001.",
      "p7": "\u0417\u0430 \u0432\u044a\u043f\u0440\u043e\u0441\u0438 \u043e\u0442\u043d\u043e\u0441\u043d\u043e \u0443\u0441\u043b\u043e\u0432\u0438\u044f\u0442\u0430 \u043c\u043e\u0436\u0435\u0442\u0435 \u0434\u0430 \u0441\u0435 \u0441\u0432\u044a\u0440\u0436\u0435\u0442\u0435 \u0441 \u0410\u0442\u043b\u0430\u043d\u0442 \u041b\u043e\u0433\u0438\u0441\u0442\u0438\u043a\u0441."
    }
  }
}
