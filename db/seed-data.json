    {
      "questionBg": "\u0418\u0437\u0432\u044a\u0440\u0448\u0432\u0430\u0442\u0435 \u043b\u0438 \u043c\u0435\u0436\u0434\u0443\u043d\u0430\u0440\u043e\u0434\u043d\u0438 \u0442\u0440\u0430\u043d\u0441\u043f\u043e\u0440\u0442\u0438?",
