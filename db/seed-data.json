    {
      "questionBg": "\u041a\u0430\u043a\u0432\u0430 \u0435 \u0441\u043a\u043b\u0430\u0434\u043e\u0432\u0430\u0442\u0430 \u0432\u0438 \u043a\u0430\u043f\u0430\u0446\u0438\u0442\u0435\u0442?",
