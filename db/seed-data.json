    {
      "questionBg": "\u0420\u0430\u0431\u043e\u0442\u0438\u0442\u0435 \u043b\u0438 \u0441 \u0431\u0438\u0437\u043d\u0435\u0441 \u043a\u043b\u0438\u0435\u043d\u0442\u0438?",
